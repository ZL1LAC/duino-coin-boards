// Copy to TestConfig.h, then: .\scripts\sync-device.ps1 lilygo-t-deck-pro

#ifndef TEST_CONFIG_H
#define TEST_CONFIG_H

#define BOARD_NAME "LilyGO T-Deck Pro"

#define SERIAL_BAUDRATE 115200

#define DISPLAY_GDEQ031T10
#define LILYGO_T_DECK_PRO

// Portrait 240x320 native. Use TFT_ROTATION 1 for landscape 320x240.
#define TFT_ROTATION 0

// V1.1 hardware (default). For V1.0 boards without RST wire, use: #define TDECK_PRO_EPD_RST -1
#ifndef TDECK_PRO_EPD_RST
  #define TDECK_PRO_EPD_RST 16
#endif

#endif